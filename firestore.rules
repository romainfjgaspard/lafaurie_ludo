rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plays/{playId} {
      allow read: if true;
      allow create: if true;
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }
  }
}
